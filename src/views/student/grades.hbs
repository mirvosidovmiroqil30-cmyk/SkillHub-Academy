<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script>if(localStorage.getItem('skillhub-theme')==='light')document.documentElement.classList.add('light-mode-pre');</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/public/css/app.css" rel="stylesheet" />
    <script src="/public/js/theme.js"></script>
    <style>
      .dark-table { width:100%; border-collapse:separate; border-spacing:0; color:#e2e8f0; }
      .dark-table thead tr { background:rgba(99,102,241,0.12); }
      .dark-table thead th { padding:.75rem 1rem; font-size:.72rem; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:#94a3b8; border-bottom:1px solid rgba(148,163,184,.14); white-space:nowrap; }
      .dark-table tbody tr { transition:background .15s; }
      .dark-table tbody tr:hover { background:rgba(99,102,241,.07); }
      .dark-table tbody td { padding:.85rem 1rem; border-bottom:1px solid rgba(148,163,184,.08); vertical-align:middle; font-size:.9rem; background:transparent; }
      .dark-table tbody tr:last-child td { border-bottom:none; }
      .section-label { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#6366f1; margin-bottom:.4rem; }
      .empty-state { padding:2.5rem 1rem; text-align:center; color:#475569; font-size:.9rem; }
      .score-pill { display:inline-flex; align-items:center; justify-content:center; min-width:3rem; padding:.2rem .6rem; border-radius:999px; font-size:.8rem; font-weight:700; }
      .score-high { background:rgba(34,197,94,.18); color:#4ade80; border:1px solid rgba(34,197,94,.3); }
      .score-mid  { background:rgba(234,179,8,.18);  color:#facc15; border:1px solid rgba(234,179,8,.3); }
      .score-low  { background:rgba(239,68,68,.18);  color:#f87171; border:1px solid rgba(239,68,68,.3); }
      .score-none { background:rgba(148,163,184,.12); color:#64748b; border:1px solid rgba(148,163,184,.2); }
    </style>
  </head>
  <body>
    <main class="container page-shell">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <p class="section-label mb-1">Talaba paneli</p>
          <h1 class="h3 mb-0" style="color:#e2e8f0;">Mening baholarim</h1>
          <p class="text-secondary mb-0" style="font-size:.85rem;">{{userName}}</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/dashboard" class="btn btn-outline-secondary btn-sm">Dashboard</a>
          <a href="/student/assignments" class="btn btn-outline-secondary btn-sm">Topshiriqlar</a>
          <form method="post" action="/logout" class="d-inline">
            <button type="submit" class="btn btn-sm" style="background:transparent;border:1px solid rgba(239,68,68,.35);color:#f87171;border-radius:6px;">Chiqish</button>
          </form>
        </div>
      </div>

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#818cf8;">{{stats.total}}</div>
            <div class="text-secondary" style="font-size:.8rem;">Jami topshiriqlar</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#4ade80;">{{stats.graded}}</div>
            <div class="text-secondary" style="font-size:.8rem;">Baholangan</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#facc15;">{{stats.pending}}</div>
            <div class="text-secondary" style="font-size:.8rem;">Kutilmoqda</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#c7d2fe;">{{stats.average}}</div>
            <div class="text-secondary" style="font-size:.8rem;">O'rtacha ball</div>
          </div>
        </div>
      </div>

      <div class="glass-card p-4 mb-4">
        <p class="section-label">Yuborilgan ishlar va baholar</p>

        {{#if submissions.length}}
          <div class="table-responsive">
            <table class="dark-table">
              <thead>
                <tr>
                  <th>Topshiriq</th>
                  <th>Fayl</th>
                  <th>Yuborilgan</th>
                  <th style="text-align:center;">Ball</th>
                  <th style="text-align:center;">Holat</th>
                </tr>
              </thead>
              <tbody>
                {{#each submissions}}
                  <tr>
                    <td>
                      <div style="display:flex;align-items:center;gap:.6rem;">
                        <div style="width:2rem;height:2rem;border-radius:8px;background:rgba(99,102,241,.18);display:flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;">📝</div>
                        <span class="fw-semibold" style="color:#c7d2fe;">{{this.assignmentTitle}}</span>
                      </div>
                    </td>
                    <td>
                      <a href="{{this.file}}" target="_blank"
                         style="color:#818cf8;font-size:.82rem;text-decoration:none;">
                        📎 Faylni ko'rish
                      </a>
                    </td>
                    <td style="color:#64748b;font-size:.82rem;white-space:nowrap;">{{this.submittedAt}}</td>
                    <td style="text-align:center;">
                      {{#if this.hasScore}}
                        {{#if this.isHigh}}
                          <span class="score-pill score-high">{{this.score}}/100</span>
                        {{else if this.isMid}}
                          <span class="score-pill score-mid">{{this.score}}/100</span>
                        {{else}}
                          <span class="score-pill score-low">{{this.score}}/100</span>
                        {{/if}}
                      {{else}}
                        <span class="score-pill score-none">—</span>
                      {{/if}}
                    </td>
                    <td style="text-align:center;">
                      {{#if this.hasScore}}
                        <span style="font-size:.75rem;color:#4ade80;">✓ Baholandi</span>
                      {{else}}
                        <span style="font-size:.75rem;color:#64748b;">⏳ Kutilmoqda</span>
                      {{/if}}
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <div class="empty-state">
            <div style="font-size:2.5rem;margin-bottom:.75rem;">📊</div>
            <div style="color:#64748b;margin-bottom:.25rem;">Hali hech qanday topshiriq yuborilmagan.</div>
            <div style="color:#475569;font-size:.8rem;">Topshiriqlarni yuborish uchun <a href="/student/assignments" style="color:#818cf8;">bu yerga</a> bosing.</div>
          </div>
        {{/if}}
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a href="/dashboard" class="btn btn-outline-secondary btn-sm">Dashboard</a>
        <a href="/courses" class="btn btn-primary btn-sm">Kurslar</a>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
