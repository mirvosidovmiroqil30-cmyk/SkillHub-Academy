<!doctype html>
<html lang="uz">
  <head>
    <meta charset="UTF-8" />
    <script>if(localStorage.getItem('skillhub-theme')==='light')document.documentElement.classList.add('light-mode-pre');</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/public/css/app.css" rel="stylesheet" />
    <script src="/public/js/theme.js"></script>
    <style>
      .section-label { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#6366f1; margin-bottom:.5rem; }

      /* Kurs qatori */
      .course-row { display:flex; align-items:flex-start; gap:.75rem; padding:.85rem 0; border-bottom:1px solid rgba(148,163,184,.08); }
      .course-row:last-child { border-bottom:none; }
      .course-avatar { width:2.2rem; height:2.2rem; border-radius:8px; background:rgba(99,102,241,.18); display:flex; align-items:center; justify-content:center; font-size:.9rem; flex-shrink:0; }
      .course-title { font-size:.92rem; font-weight:600; color:#c7d2fe; }
      .course-desc { font-size:.78rem; color:#64748b; margin-top:.15rem; overflow:hidden; display:-webkit-box; -webkit-line-clamp:1; -webkit-box-orient:vertical; }

      /* Deadline qatori */
      .deadline-row { display:flex; align-items:center; gap:.75rem; padding:.75rem 0; border-bottom:1px solid rgba(148,163,184,.08); }
      .deadline-row:last-child { border-bottom:none; }
      .deadline-dot { width:.55rem; height:.55rem; border-radius:50%; background:#f87171; flex-shrink:0; }
      .deadline-title { font-size:.88rem; font-weight:600; color:#e2e8f0; }
      .deadline-time { font-size:.75rem; color:#64748b; margin-top:.1rem; }

      /* Submit karta */
      .submit-card { background:rgba(12,18,34,.85); border:1px solid rgba(148,163,184,.12); border-radius:14px; padding:1.1rem; transition:border-color .2s; }
      .submit-card:hover { border-color:rgba(99,102,241,.35); }

      /* Stat karta */
      .stat-num { font-size:2rem; font-weight:700; line-height:1; }

      /* Empty state */
      .empty-state { padding:2rem 1rem; text-align:center; color:#475569; font-size:.88rem; }
    </style>
  </head>
  <body>
    <main class="container page-shell">

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <p class="section-label mb-1">Talaba paneli</p>
          <h1 class="h3 mb-0" style="color:#e2e8f0;">Xush kelibsiz, {{userName}}</h1>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <a href="/courses" class="btn btn-outline-secondary btn-sm">Kurslar</a>
          <a href="/student/assignments" class="btn btn-outline-secondary btn-sm">Topshiriqlar</a>
          <a href="/student/grades" class="btn btn-outline-secondary btn-sm">Baholar</a>
          <a href="/profile" class="btn btn-outline-secondary btn-sm">Profil</a>
          <form method="post" action="/logout" class="d-inline">
            <button type="submit" class="btn btn-sm" style="background:transparent;border:1px solid rgba(239,68,68,.35);color:#f87171;border-radius:6px;">Chiqish</button>
          </form>
        </div>
      </div>

      <!-- Alerts -->
      {{#if success}}
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
          {{success}}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}
      {{#if error}}
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
          {{error}}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-4">
          <div class="glass-card p-3 text-center">
            <div class="stat-num mb-1" style="color:#818cf8;">{{stats.courses}}</div>
            <div class="text-secondary" style="font-size:.78rem;">Kurslar</div>
          </div>
        </div>
        <div class="col-4">
          <div class="glass-card p-3 text-center">
            <div class="stat-num mb-1" style="color:#f87171;">{{stats.assignments}}</div>
            <div class="text-secondary" style="font-size:.78rem;">Topshiriqlar</div>
          </div>
        </div>
        <div class="col-4">
          <div class="glass-card p-3 text-center">
            <div class="stat-num mb-1" style="color:#4ade80;">{{stats.submissions}}</div>
            <div class="text-secondary" style="font-size:.78rem;">Yuborilgan</div>
          </div>
        </div>
      </div>

      <!-- Kurslar + Deadlines -->
      <div class="row g-3 mb-4">

        <!-- Mening kurslarim -->
        <div class="col-lg-7">
          <div class="glass-card p-4 h-100">
            <p class="section-label">Mening kurslarim</p>
            {{#if myCourses.length}}
              {{#each myCourses}}
                <div class="course-row">
                  <div class="course-avatar">📚</div>
                  <div style="min-width:0;">
                    <div class="course-title">{{this.title}}</div>
                    <div class="course-desc">
                      {{#if this.description}}{{this.description}}{{else}}Tavsif yo'q{{/if}}
                    </div>
                  </div>
                </div>
              {{/each}}
            {{else}}
              <div class="empty-state">
                <div style="font-size:2rem;margin-bottom:.5rem;">📭</div>
                Hali birorta kursga yozilmagansiz.<br>
                <a href="/courses" style="color:#818cf8;font-size:.82rem;">Kurslarni ko'rish →</a>
              </div>
            {{/if}}
          </div>
        </div>

        <!-- Yaqinlashayotgan deadlinelar -->
        <div class="col-lg-5">
          <div class="glass-card p-4 h-100">
            <p class="section-label">Yaqin muddatlar</p>
            {{#if upcomingAssignments.length}}
              {{#each upcomingAssignments}}
                <div class="deadline-row">
                  <div class="deadline-dot"></div>
                  <div style="min-width:0;">
                    <div class="deadline-title">{{this.title}}</div>
                    <div class="deadline-time">⏰ {{this.deadline}}</div>
                  </div>
                </div>
              {{/each}}
            {{else}}
              <div class="empty-state">
                <div style="font-size:2rem;margin-bottom:.5rem;">✅</div>
                Yaqin muddatli topshiriq yo'q.
              </div>
            {{/if}}
          </div>
        </div>
      </div>

      <!-- Topshiriq yuborish -->
      {{#if upcomingAssignments.length}}
        <div class="glass-card p-4 mb-4">
          <p class="section-label">Topshiriq yuborish</p>
          <div class="row g-3">
            {{#each upcomingAssignments}}
              <div class="col-md-6">
                <div class="submit-card">
                  <div class="fw-semibold mb-1" style="color:#c7d2fe;">{{this.title}}</div>
                  <div style="font-size:.75rem;color:#64748b;margin-bottom:.75rem;">⏰ {{this.deadline}}</div>
                  <form method="post" action="/assignments/{{this.id}}/submit" enctype="multipart/form-data">
                    <input type="file" name="file" class="form-control form-control-sm mb-2" required
                           accept=".pdf,.doc,.docx,.zip,.txt,.png,.jpg,.jpeg" />
                    <button class="btn btn-primary btn-sm w-100" type="submit">📤 Yuborish</button>
                  </form>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
