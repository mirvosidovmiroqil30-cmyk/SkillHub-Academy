<!doctype html>
<html lang="uz">
  <head>
    <meta charset="UTF-8" />
    <script>if(localStorage.getItem('skillhub-theme')==='light')document.documentElement.classList.add('light-mode-pre');</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/public/css/app.css" rel="stylesheet" />
    <script src="/public/js/theme.js"></script>
    <style>
      .section-label { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#6366f1; margin-bottom:.4rem; }
      .dark-table { width:100%; border-collapse:separate; border-spacing:0; color:#e2e8f0; }
      .dark-table thead tr { background:rgba(99,102,241,.12); }
      .dark-table thead th { padding:.75rem 1rem; font-size:.72rem; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:#94a3b8; border-bottom:1px solid rgba(148,163,184,.14); white-space:nowrap; }
      .dark-table tbody tr { transition:background .15s; }
      .dark-table tbody tr:hover { background:rgba(99,102,241,.07); }
      .dark-table tbody td { padding:.85rem 1rem; border-bottom:1px solid rgba(148,163,184,.08); vertical-align:middle; font-size:.9rem; background:transparent; }
      .dark-table tbody tr:last-child td { border-bottom:none; }

      .empty-state { padding:3rem 1rem; text-align:center; color:#475569; }

      .score-pill { display:inline-flex; align-items:center; justify-content:center; min-width:3rem; padding:.2rem .65rem; border-radius:999px; font-size:.8rem; font-weight:700; }
      .score-high { background:rgba(34,197,94,.18); color:#4ade80; border:1px solid rgba(34,197,94,.3); }
      .score-mid  { background:rgba(234,179,8,.18);  color:#facc15; border:1px solid rgba(234,179,8,.3); }
      .score-low  { background:rgba(239,68,68,.18);  color:#f87171; border:1px solid rgba(239,68,68,.3); }
      .score-none { background:rgba(148,163,184,.1); color:#64748b; border:1px solid rgba(148,163,184,.2); font-style:italic; }

      .btn-ghost-danger { background:transparent; border:1px solid rgba(239,68,68,.35); color:#f87171; font-size:.75rem; padding:.25rem .65rem; border-radius:6px; }
      .btn-ghost-danger:hover { background:rgba(239,68,68,.12); border-color:rgba(239,68,68,.6); color:#fca5a5; }

      .score-input { background:rgba(15,23,42,.8); border:1px solid rgba(148,163,184,.2); color:#e2e8f0; border-radius:6px; padding:.3rem .6rem; font-size:.82rem; width:72px; text-align:center; }
      .score-input:focus { outline:none; border-color:rgba(99,102,241,.5); box-shadow:0 0 0 2px rgba(99,102,241,.15); }

      .btn-save { background:rgba(99,102,241,.2); border:1px solid rgba(99,102,241,.35); color:#a5b4fc; font-size:.75rem; padding:.3rem .75rem; border-radius:6px; cursor:pointer; transition:background .15s; white-space:nowrap; }
      .btn-save:hover { background:rgba(99,102,241,.35); color:#c7d2fe; }

      .student-cell { display:flex; align-items:center; gap:.6rem; }
      .student-avatar { width:2rem; height:2rem; border-radius:50%; background:rgba(99,102,241,.2); display:flex; align-items:center; justify-content:center; font-size:.8rem; flex-shrink:0; color:#818cf8; font-weight:700; }
    </style>
  </head>
  <body>
    <main class="container page-shell">

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <p class="section-label mb-1">O'qituvchi paneli</p>
          <h1 class="h3 mb-0" style="color:#e2e8f0;">Yuborilgan ishlar</h1>
        </div>
        <div class="d-flex gap-2">
          <a href="/teacher/courses" class="btn btn-outline-secondary btn-sm">← Kurslar</a>
          <form method="post" action="/logout" class="d-inline">
            <button type="submit" class="btn btn-sm btn-ghost-danger">Chiqish</button>
          </form>
        </div>
      </div>

      <!-- Alerts -->
      {{#if success}}
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
          {{success}}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}
      {{#if error}}
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
          {{error}}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#818cf8;">{{submissions.length}}</div>
            <div class="text-secondary" style="font-size:.78rem;">Jami</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#4ade80;" id="graded-count">—</div>
            <div class="text-secondary" style="font-size:.78rem;">Baholangan</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#facc15;" id="pending-count">—</div>
            <div class="text-secondary" style="font-size:.78rem;">Kutilmoqda</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="glass-card p-3 text-center">
            <div class="fw-bold mb-1" style="font-size:1.8rem;color:#c7d2fe;" id="avg-score">—</div>
            <div class="text-secondary" style="font-size:.78rem;">O'rtacha ball</div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="glass-card p-4 mb-4">
        <p class="section-label">Barcha topshiriqlar</p>

        {{#if submissions.length}}
          <div class="table-responsive">
            <table class="dark-table" id="submissions-table">
              <thead>
                <tr>
                  <th>Talaba</th>
                  <th>Topshiriq</th>
                  <th style="text-align:center;">Fayl</th>
                  <th style="text-align:center;">Ball</th>
                  <th style="text-align:right;">Baholash</th>
                </tr>
              </thead>
              <tbody>
                {{#each submissions}}
                  <tr data-score="{{this.score}}">
                    <td>
                      <div class="student-cell">
                        <div class="student-avatar">
                          {{#if this.student}}{{this.student.[0]}}{{else}}?{{/if}}
                        </div>
                        <span class="fw-semibold" style="color:#c7d2fe;">{{this.student}}</span>
                      </div>
                    </td>
                    <td>
                      <div style="color:#e2e8f0;font-weight:500;">{{this.assignment}}</div>
                    </td>
                    <td style="text-align:center;">
                      <a href="{{this.file}}" target="_blank"
                         style="color:#818cf8;font-size:.82rem;text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;">
                        📎 Ko'rish
                      </a>
                    </td>
                    <td style="text-align:center;">
                      {{#if this.hasScore}}
                        <span class="score-pill {{this.scoreClass}}">
                          {{this.score}}/100
                        </span>
                      {{else}}
                        <span class="score-pill score-none">Baholanmagan</span>
                      {{/if}}
                    </td>
                    <td style="text-align:right;">
                      <form method="post" action="/teacher/submissions/{{this.id}}/score"
                            class="d-flex gap-2 justify-content-end align-items-center">
                        <input type="number" min="0" max="100" name="score"
                               class="score-input"
                               placeholder="0–100"
                               value="{{#if this.score}}{{this.score}}{{/if}}"
                               required />
                        <button class="btn-save" type="submit">Saqlash</button>
                      </form>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <div class="empty-state">
            <div style="font-size:2.5rem;margin-bottom:.75rem;">📭</div>
            <div style="color:#64748b;">Hozircha yuborilgan ishlar mavjud emas.</div>
          </div>
        {{/if}}
      </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Statistikani JS da hisoblash
      (function () {
        var rows = document.querySelectorAll('#submissions-table tbody tr');
        if (!rows.length) return;
        var graded = 0, total = 0, sum = 0;
        rows.forEach(function (row) {
          var s = row.getAttribute('data-score');
          if (s && s !== '' && s !== 'null') {
            graded++;
            sum += parseInt(s, 10);
          }
          total++;
        });
        var pending = total - graded;
        var avg = graded > 0 ? Math.round(sum / graded) : '—';
        document.getElementById('graded-count').textContent = graded;
        document.getElementById('pending-count').textContent = pending;
        document.getElementById('avg-score').textContent = graded > 0 ? avg : '—';
      })();
    </script>
  </body>
</html>
