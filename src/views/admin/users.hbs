<!doctype html>
<html lang="uz">
  <head>
    <meta charset="UTF-8" />
    <script>if(localStorage.getItem('skillhub-theme')==='light')document.documentElement.classList.add('light-mode-pre');</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/public/css/app.css" rel="stylesheet" />
    <script src="/public/js/theme.js"></script>
    <style>
      .dark-table { width:100%; border-collapse:separate; border-spacing:0; color:#e2e8f0; }
      .dark-table thead tr { background:rgba(99,102,241,0.12); }
      .dark-table thead th { padding:.75rem 1rem; font-size:.72rem; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:#94a3b8; border-bottom:1px solid rgba(148,163,184,.14); white-space:nowrap; }
      .dark-table tbody tr { transition:background .15s; }
      .dark-table tbody tr:hover { background:rgba(99,102,241,.07); }
      .dark-table tbody td { padding:.85rem 1rem; border-bottom:1px solid rgba(148,163,184,.08); vertical-align:middle; font-size:.9rem; background:transparent; }
      .dark-table tbody tr:last-child td { border-bottom:none; }
      .section-label { font-size:.7rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#6366f1; margin-bottom:.4rem; }
      .btn-ghost-danger { background:transparent; border:1px solid rgba(239,68,68,.35); color:#f87171; font-size:.75rem; padding:.25rem .65rem; border-radius:6px; }
      .btn-ghost-danger:hover { background:rgba(239,68,68,.12); border-color:rgba(239,68,68,.6); color:#fca5a5; }
      .btn-ghost-success { background:transparent; border:1px solid rgba(34,197,94,.35); color:#4ade80; font-size:.75rem; padding:.25rem .65rem; border-radius:6px; }
      .btn-ghost-success:hover { background:rgba(34,197,94,.12); border-color:rgba(34,197,94,.6); color:#86efac; }
    </style>
  </head>
  <body>
    <main class="container page-shell">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <p class="section-label mb-1">Admin panel</p>
          <h1 class="h3 mb-1" style="color:#e2e8f0;">Foydalanuvchilar</h1>
          <p class="text-secondary mb-0">Salom, {{userName}}</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/admin/courses" class="btn btn-outline-secondary btn-sm">Kurslar</a>
          <a href="/admin/categories" class="btn btn-outline-secondary btn-sm">Kategoriyalar</a>
          <form method="post" action="/logout" class="d-inline">
            <button type="submit" class="btn btn-sm btn-ghost-danger">Chiqish</button>
          </form>
        </div>
      </div>

      {{#if success}}
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
          {{success}}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}
      {{#if error}}
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
          {{error}}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}

      <!-- Stats -->
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <div class="glass-card p-4 text-center">
            <h3 class="fw-bold mb-1" style="color:#818cf8;">{{stats.totalUsers}}</h3>
            <p class="text-secondary mb-0">Jami foydalanuvchilar</p>
          </div>
        </div>
        <div class="col-md-6">
          <div class="glass-card p-4 text-center">
            <h3 class="fw-bold mb-1" style="color:#4ade80;">{{stats.activeUsers}}</h3>
            <p class="text-secondary mb-0">Faol foydalanuvchilar</p>
          </div>
        </div>
      </div>

      <div class="glass-card p-4 mb-4">
        <p class="section-label">Foydalanuvchilar ro'yxati</p>
        <div class="table-responsive">
          <table class="dark-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Ism</th>
                <th>Email</th>
                <th>Rol</th>
                <th style="text-align:center;">Holat</th>
                <th style="text-align:right;">Amallar</th>
              </tr>
            </thead>
            <tbody>
              {{#each users}}
                <tr>
                  <td style="color:#64748b;">{{this.id}}</td>
                  <td class="fw-semibold" style="color:#c7d2fe;">{{this.full_name}}</td>
                  <td style="color:#94a3b8;">{{this.email}}</td>
                  <td>
                    {{#if (eq this.role 'admin')}}
                      <span class="badge" style="background:rgba(239,68,68,.2);color:#f87171;border:1px solid rgba(239,68,68,.3);">admin</span>
                    {{else if (eq this.role 'teacher')}}
                      <span class="badge" style="background:rgba(99,102,241,.2);color:#818cf8;border:1px solid rgba(99,102,241,.3);">teacher</span>
                    {{else}}
                      <span class="badge" style="background:rgba(34,197,94,.15);color:#4ade80;border:1px solid rgba(34,197,94,.25);">student</span>
                    {{/if}}
                  </td>
                  <td style="text-align:center;">
                    {{#if this.is_active}}
                      <span class="badge" style="background:rgba(34,197,94,.15);color:#4ade80;border:1px solid rgba(34,197,94,.25);">Faol</span>
                    {{else}}
                      <span class="badge" style="background:rgba(148,163,184,.1);color:#64748b;border:1px solid rgba(148,163,184,.2);">Nofaol</span>
                    {{/if}}
                  </td>
                  <td style="text-align:right;">
                    <div class="d-flex gap-1 justify-content-end flex-wrap">
                      <!-- Toggle active -->
                      <form method="post" action="/admin/users/{{this.id}}/toggle-active" class="d-inline">
                        {{#if this.is_active}}
                          <button class="btn-ghost-danger" type="submit">Bloklash</button>
                        {{else}}
                          <button class="btn-ghost-success" type="submit">Faollashtirish</button>
                        {{/if}}
                      </form>

                      <!-- Change role -->
                      <form method="post" action="/admin/users/{{this.id}}/change-role" class="d-inline">
                        <select name="role" class="form-select form-select-sm d-inline-block" style="width:auto;font-size:.75rem;background:rgba(15,23,42,.8);color:#e2e8f0;border:1px solid rgba(148,163,184,.2);" onchange="this.form.submit()">
                          <option value="student" {{#if (eq this.role 'student')}}selected{{/if}}>student</option>
                          <option value="teacher" {{#if (eq this.role 'teacher')}}selected{{/if}}>teacher</option>
                          <option value="admin" {{#if (eq this.role 'admin')}}selected{{/if}}>admin</option>
                        </select>
                      </form>

                      <!-- Delete -->
                      <form method="post" action="/admin/users/{{this.id}}/delete" class="d-inline">
                        <button class="btn-ghost-danger" type="submit" onclick="return confirm('Foydalanuvchini o\'chirishni tasdiqlaysizmi?')">O'chirish</button>
                      </form>
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
