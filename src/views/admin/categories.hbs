<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script>if(localStorage.getItem('skillhub-theme')==='light')document.documentElement.classList.add('light-mode-pre');</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/public/css/app.css" rel="stylesheet" />
    <script src="/public/js/theme.js"></script>
    <style>
      .dark-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        color: #e2e8f0;
      }
      .dark-table thead tr {
        background: rgba(99, 102, 241, 0.12);
      }
      .dark-table thead th {
        padding: 0.75rem 1rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #94a3b8;
        border-bottom: 1px solid rgba(148, 163, 184, 0.14);
        white-space: nowrap;
      }
      .dark-table tbody tr {
        transition: background 0.15s;
      }
      .dark-table tbody tr:hover {
        background: rgba(99, 102, 241, 0.07);
      }
      .dark-table tbody td {
        padding: 0.85rem 1rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.08);
        vertical-align: middle;
        font-size: 0.9rem;
        background: transparent;
      }
      .dark-table tbody tr:last-child td {
        border-bottom: none;
      }

      .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #6366f1;
        margin-bottom: 0.4rem;
      }
      .section-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: #e2e8f0;
        margin-bottom: 1.25rem;
      }
      .card-divider {
        border: none;
        border-top: 1px solid rgba(148, 163, 184, 0.1);
        margin: 1.5rem 0;
      }
      .empty-state {
        padding: 2.5rem 1rem;
        text-align: center;
        color: #475569;
        font-size: 0.9rem;
      }
      .btn-ghost-danger {
        background: transparent;
        border: 1px solid rgba(239, 68, 68, 0.35);
        color: #f87171;
        font-size: 0.75rem;
        padding: 0.25rem 0.65rem;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
      }
      .btn-ghost-danger:hover {
        background: rgba(239, 68, 68, 0.12);
        border-color: rgba(239, 68, 68, 0.6);
        color: #fca5a5;
      }
      .badge-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.6rem;
        height: 1.6rem;
        padding: 0 0.45rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        background: rgba(99, 102, 241, 0.22);
        color: #a5b4fc;
        border: 1px solid rgba(99, 102, 241, 0.3);
      }
      .cat-icon {
        width: 2rem;
        height: 2rem;
        border-radius: 8px;
        background: rgba(99, 102, 241, 0.18);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
      }
    </style>
  </head>
  <body>
    <main class="container page-shell">

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <p class="section-label mb-1">Admin Panel</p>
          <h1 class="h3 mb-0" style="color:#e2e8f0;">Kategoriyalar</h1>
          <p class="text-secondary mb-0" style="font-size:0.85rem;">Salom, {{userName}}</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/admin/users" class="btn btn-outline-secondary btn-sm">Foydalanuvchilar</a>
          <a href="/admin/courses" class="btn btn-outline-secondary btn-sm">Kurslar</a>
          <form method="post" action="/logout" class="d-inline">
            <button type="submit" class="btn-ghost-danger" style="padding:0.35rem 0.8rem;">Chiqish</button>
          </form>
        </div>
      </div>

      <!-- Alerts -->
      {{#if success}}
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
          {{success}}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}
      {{#if error}}
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
          {{error}}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}

      <!-- Create form -->
      <div class="glass-card p-4 mb-4">
        <p class="section-label">Yangi kategoriya</p>
        <h5 class="section-title">Kategoriya yaratish</h5>

        <form method="post" action="/admin/categories" class="row g-2">
          <div class="col-md-4">
            <input
              class="form-control"
              name="name"
              placeholder="Kategoriya nomi"
              required
            />
          </div>
          <div class="col-md-6">
            <input
              class="form-control"
              name="description"
              placeholder="Tavsif (ixtiyoriy)"
            />
          </div>
          <div class="col-md-2">
            <button class="btn btn-primary w-100" type="submit">Yaratish</button>
          </div>
        </form>
      </div>

      <!-- Categories list -->
      <div class="glass-card p-4 mb-4">
        <p class="section-label">Bazadagi kategoriyalar</p>

        {{#if categories.length}}
          <div class="table-responsive">
            <table class="dark-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Kategoriya</th>
                  <th>Tavsif</th>
                  <th style="text-align:center;">Kurslar</th>
                  <th>Yaratilgan</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {{#each categories}}
                  <tr>
                    <td style="color:#475569;font-size:0.8rem;">{{this.id}}</td>
                    <td>
                      <div style="display:flex;align-items:center;gap:0.6rem;">
                        <div class="cat-icon">🏷️</div>
                        <span class="fw-semibold" style="color:#c7d2fe;">{{this.name}}</span>
                      </div>
                    </td>
                    <td style="color:#94a3b8;max-width:260px;">
                      {{#if this.description}}
                        <span style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                          {{this.description}}
                        </span>
                      {{else}}
                        <span style="color:#475569;font-style:italic;">—</span>
                      {{/if}}
                    </td>
                    <td style="text-align:center;">
                      <span class="badge-count">{{this.courseCount}}</span>
                    </td>
                    <td style="color:#64748b;font-size:0.82rem;white-space:nowrap;">
                      {{this.created_at}}
                    </td>
                    <td style="text-align:right;">
                      <form
                        method="post"
                        action="/admin/categories/{{this.id}}/delete"
                        class="d-inline"
                        onsubmit="return confirm('«{{this.name}}» kategoriyasini o\'chirishni tasdiqlaysizmi?')"
                      >
                        <button class="btn-ghost-danger" type="submit">O'chirish</button>
                      </form>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>

          <!-- Summary -->
          <div class="mt-3 d-flex align-items-center gap-2" style="color:#475569;font-size:0.82rem;">
            <span>Jami:</span>
            <span class="badge-count">{{categories.length}}</span>
            <span>ta kategoriya</span>
          </div>

        {{else}}
          <div class="empty-state">
            <div style="font-size:2.5rem;margin-bottom:0.75rem;">🏷️</div>
            <div style="color:#64748b;margin-bottom:0.25rem;">Hozircha kategoriyalar mavjud emas.</div>
            <div style="color:#475569;font-size:0.8rem;">Yuqoridagi forma orqali birinchi kategoriyani yarating.</div>
          </div>
        {{/if}}
      </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
