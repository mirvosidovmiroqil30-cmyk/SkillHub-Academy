<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script>if(localStorage.getItem('skillhub-theme')==='light')document.documentElement.classList.add('light-mode-pre');</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/public/css/app.css" rel="stylesheet" />
    <script src="/public/js/theme.js"></script>
  </head>
  <body>
    <div class="container page-shell">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h3 mb-1">Course Catalog</h1>
          <p class="text-secondary mb-0">Barcha mavjud kurslar ro'yxati</p>
        </div>
        <div class="d-flex gap-2">
          <a href="/" class="btn btn-outline-secondary btn-sm">Home</a>
          {{#if (eq userRole 'student')}}
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm">Dashboard</a>
          {{else if (eq userRole 'teacher')}}
            <a href="/teacher/courses" class="btn btn-outline-secondary btn-sm">Panel</a>
          {{else if (eq userRole 'admin')}}
            <a href="/admin/users" class="btn btn-outline-secondary btn-sm">Admin</a>
          {{else}}
            <a href="/login" class="btn btn-primary btn-sm">Kirish</a>
            <a href="/register" class="btn btn-outline-primary btn-sm">Ro'yxatdan o'tish</a>
          {{/if}}
        </div>
      </div>

      {{#if success}}
        <div class="alert alert-success">{{success}}</div>
      {{/if}}
      {{#if error}}
        <div class="alert alert-danger">{{error}}</div>
      {{/if}}

      <div class="mb-4">
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <span class="text-secondary">Filter by category:</span>
          <a href="/courses" class="btn btn-sm btn-outline-primary">All</a>
          {{#each categories}}
            <a href="/courses?category={{this.name}}" class="btn btn-sm btn-outline-primary">{{this.name}}</a>
          {{/each}}
        </div>
      </div>

      <div class="row g-3">
        {{#if courses.length}}
          {{#each courses}}
            <div class="col-md-6 col-lg-4">
              <div class="glass-card p-3 h-100">
                {{#if this.image}}
                  <img
                    src="{{this.image}}"
                    alt="{{this.title}}"
                    class="img-fluid rounded mb-3"
                    style="height: 170px; object-fit: cover; width: 100%"
                  />
                {{/if}}
                <h5 class="mb-1">{{this.title}}</h5>
                <p class="text-secondary small mb-2">
                  Teacher: {{this.teacher}} {{#if this.category}}• Category: {{this.category}}{{/if}}
                </p>
                <p class="text-secondary mb-3">
                  {{#if this.description}}{{this.description}}{{else}}No description yet.{{/if}}
                </p>
                {{#if (eq ../userRole 'student')}}
                  <form method="post" action="/courses/{{this.id}}/enroll">
                    <button class="btn btn-primary w-100" type="submit">
                      Kursga yozilish
                    </button>
                  </form>
                {{else if ../userRole}}
                  {{! teacher yoki admin — enroll tugmasi ko'rsatilmaydi }}
                {{else}}
                  <a class="btn btn-outline-primary w-100" href="/login">Kursga yozilish uchun kiring</a>
                {{/if}}
              </div>
            </div>
          {{/each}}
        {{else}}
          <div class="col-12">
            <div class="glass-card p-4 text-center text-secondary">
              Hozircha kurslar yo'q.
            </div>
          </div>
        {{/if}}
      </div>
    </div>
  </body>
</html>
